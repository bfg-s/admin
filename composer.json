{
    "name": "bfg/admin",
    "description": "A group of components for generating standard-shaded components that make up the essence of the control panel.",
    "type": "bfg-script",
    "license": "MIT",
    "authors": [
        {
            "name": "bfg",
            "email": "bfg.script@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.0.0",
        "bfg/layout": "^1.0.0"
    },
    "require-dev": {
    },
    "autoload": {
        "psr-4": {
            "Bfg\\Admin\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bfg\\Admin\\ServiceProvider"
            ],
            "aliases": {
                "Admin": "Bfg\\Admin\\Facade"
            }
        }
    }
}
